{
  "name": "egpdf",
  "productName": "egPDF",
  "version": "0.1.1",
  "description": "Minimal local PDF reader and editor",
  "main": "main.js",
  "scripts": {
    "build": "node build.mjs",
    "start": "npm run build && electron .",
    "test": "node test/run.mjs",
    "test:packaged": "node test/run.mjs --packaged",
    "dist": "npm run build && electron-builder --mac --win --linux --publish never"
  },
  "author": "Aziz Can Cengiz",
  "license": "MIT",
  "build": {
    "appId": "com.azizcancengiz.egpdf",
    "productName": "egPDF",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/styles.css",
      "dist/**",
      "!node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": true
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Viewer"
      }
    ]
  },
  "devDependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.24.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38"
  }
}
